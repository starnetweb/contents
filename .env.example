# ── Database ──────────────────────────────────────────────────
# SQLite path (Docker volume, do not change)
DATABASE_URL=sqlite:////app/data/content_agent.db

# ── Security ──────────────────────────────────────────────────
SECRET_KEY=replace-this-with-a-long-random-secret-key-at-least-32-chars

# ── AI & Search APIs ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
TAVILY_API_KEY=tvly-...

# ── Telegram Bot ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Brand Telegram Chat IDs (get by adding bot to group, then /getid)
TELEGRAM_BLAZINGPROJECTS_CHAT_ID=-100...
TELEGRAM_EXAMKITS_CHAT_ID=-100...
TELEGRAM_WATMALL_CHAT_ID=-100...
TELEGRAM_PAYAPP_CHAT_ID=-100...
TELEGRAM_REALTOUR_CHAT_ID=-100...
TELEGRAM_STANETACADEMY_CHAT_ID=-100...

# ── Server ────────────────────────────────────────────────────
PORT=4001
FRONTEND_URL=http://YOUR_VPS_IP:3000
