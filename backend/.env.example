# ─── Database ─────────────────────────────────────────────
DATABASE_URL=sqlite:///./content_agent.db

# ─── Auth (JWT) ────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Anthropic Claude API ──────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Tavily Search API ─────────────────────────────────────
# Get from: https://tavily.com (free tier: 1000 searches/month)
TAVILY_API_KEY=tvly-...

# ─── Telegram ──────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# One Telegram chat ID per brand
# To get chat ID: add bot to group → send a message → visit
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BLAZINGPROJECTS_CHAT_ID=-100...
TELEGRAM_EXAMKITS_CHAT_ID=-100...
TELEGRAM_WATMALL_CHAT_ID=-100...
TELEGRAM_PAYAPP_CHAT_ID=-100...
TELEGRAM_REALTOUR_CHAT_ID=-100...
TELEGRAM_STANET_CHAT_ID=-100...

# ─── Server ────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000
